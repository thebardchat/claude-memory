# ShaneBrain canonical service locations.
#
# Hooks and any other infra-aware scripts source this file. Update one place,
# commit, every node `git pull`s — every hook on every node now points at the
# new location. The Phase 3 migration (Weaviate + n8n → neworleans) becomes a
# two-line change here, not a sweep across scripts.
#
# Env-var override on any node still wins (SHANEBRAIN_WEAVIATE_URL etc.) for
# emergency redirection without a commit.

# Weaviate — currently on shanebrain (Pi 5). Phase 3 target: neworleans.
SHANEBRAIN_WEAVIATE_HOST=shanebrain
SHANEBRAIN_WEAVIATE_PORT=8080

# MCP server — currently on shanebrain (Pi 5). Stays on Pi (latency-sensitive
# to local Ollama). Phase 3 target: unchanged.
SHANEBRAIN_MCP_HOST=shanebrain
SHANEBRAIN_MCP_PORT=8100

# Angel Cloud Gateway — public-facing proxy. Stays on Pi.
SHANEBRAIN_GATEWAY_HOST=shanebrain
SHANEBRAIN_GATEWAY_PORT=4200

# n8n — currently on shanebrain. Phase 3 target: neworleans (cron-distill).
SHANEBRAIN_N8N_HOST=shanebrain
SHANEBRAIN_N8N_PORT=5678
